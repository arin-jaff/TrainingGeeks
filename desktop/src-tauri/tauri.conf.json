{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TrainingGeeks",
  "version": "0.1.0",
  "identifier": "com.traininggeeks.app",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TrainingGeeks",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "resources": {
      "../server": "server"
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-",
      "hardenedRuntime": false
    }
  }
}