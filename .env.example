# TrainingGeeks configuration — copy to .env.local and fill in.
# All variables are optional, but for any networked deployment set BOTH
# TG_PASSWORD and TG_SESSION_SECRET (auth fails closed without the secret).

# Gate access with a single password. If unset, the app runs WITHOUT auth —
# only safe on localhost / a fully trusted network.
TG_PASSWORD=

# Secret used to sign session cookies. REQUIRED when TG_PASSWORD is set.
# Use a long random value, e.g.:  openssl rand -hex 32
TG_SESSION_SECRET=

# intervals.icu sync (also settable in Settings → Apps & Devices).
# Find these at intervals.icu → Settings → Developer.
TG_INTERVALS_ATHLETE_ID=
TG_INTERVALS_API_KEY=

# Bearer token that lets a background sync daemon call POST /api/sync and
# guards the calendar .ics feed (?token=...). Use a long random value.
TG_SYNC_TOKEN=
