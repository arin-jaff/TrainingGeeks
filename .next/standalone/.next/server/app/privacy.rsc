9:["$","section",null,{"className":"mt-8","children":[["$","h2",null,{"className":"text-lg font-semibold text-ink","children":"Where your data lives"}],["$","div",null,{"className":"mt-2 space-y-3 text-sm leading-relaxed text-ink-muted","children":["$","p",null,{"children":"All of the above is stored in a local SQLite database on the machine running TrainingGeeks. It is never sent to us — because there is no \"us\" with a server. Backups, disk encryption, and access to that machine are under your control."}]}]]}]
a:["$","section",null,{"className":"mt-8","children":[["$","h2",null,{"className":"text-lg font-semibold text-ink","children":"Third-party services"}],["$","div",null,{"className":"mt-2 space-y-3 text-sm leading-relaxed text-ink-muted","children":["$","p",null,{"children":["TrainingGeeks integrates with ",["$","a",null,{"className":"text-accent hover:underline","href":"https://intervals.icu","target":"_blank","rel":"noreferrer","children":"intervals.icu"}],", and only when ",["$","em",null,{"children":"you"}]," enter your own Athlete ID and API key to enable sync. When enabled, your instance exchanges activity and planned-workout data directly with intervals.icu under",["$","a",null,{"className":"text-accent hover:underline","href":"https://intervals.icu/privacy","target":"_blank","rel":"noreferrer","children":" their privacy policy"}],". Remove the key to stop syncing. No other third parties receive your data."]}]}]]}]
